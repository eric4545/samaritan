{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://samaritan.dev/schemas/operation.json",
  "title": "SAMARITAN Operation",
  "description": "Schema for SAMARITAN operation definitions",
  "type": "object",
  "required": ["name", "version", "steps"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Operation name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (e.g., 1.0.0)"
    },
    "description": {
      "type": "string",
      "description": "Operation description"
    },
    "author": {
      "type": "string",
      "description": "Operation author"
    },
    "category": {
      "type": "string",
      "description": "Operation category"
    },
    "overview": {
      "type": "object",
      "description": "Flexible overview/metadata section with custom fields (e.g., Release Date, Release Notes, etc.)"
    },
    "needs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Required operation dependencies"
    },
    "uses": {
      "type": "string",
      "description": "Marketplace operation reference"
    },
    "with": {
      "type": "object",
      "description": "Parameters for marketplace operation"
    },
    "environments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "from": {
            "type": "string",
            "description": "Inherit environment definition from manifest"
          },
          "description": {
            "type": "string"
          },
          "variables": {
            "type": "object"
          },
          "targets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "approval_required": {
            "type": "boolean"
          },
          "validation_required": {
            "type": "boolean"
          },
          "restrictions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "variables": {
      "type": "object",
      "description": "Variables shared across all environments (convenience alias of common_variables; common_variables wins on key conflict)"
    },
    "common_variables": {
      "type": "object",
      "description": "Common variables shared across all environments (can be overridden by environment-specific variables)"
    },
    "env_file": {
      "type": "string",
      "description": "Path to .env file for loading variables (lowest priority in variable lookup)"
    },
    "sessions": {
      "type": "object",
      "description": "Named tmux sessions for execution engine",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "host": {
            "type": "string",
            "description": "SSH host (omit for local)"
          },
          "user": { "type": "string", "description": "SSH user" },
          "env": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Environment variables to set on connect"
          }
        },
        "additionalProperties": false
      }
    },
    "run": {
      "type": "object",
      "description": "Run-mode configuration for the execution engine",
      "properties": {
        "auto_send": {
          "type": "boolean",
          "default": false,
          "description": "Auto-load command text into terminal when step starts"
        },
        "auto_exec": {
          "type": "boolean",
          "default": false,
          "description": "Auto-press Enter after send"
        }
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["uses"],
            "properties": {
              "uses": {
                "type": "string",
                "minLength": 1,
                "description": "File whose steps are expanded inline here: local path (relative to operation file), HTTPS URL, or github:owner/repo//path@ref shorthand"
              },
              "with": {
                "type": "object",
                "description": "Variables to pass to the included file (all ${VAR} placeholders must be provided)"
              }
            },
            "description": "Inline step composition — expands all steps from the referenced file at this position"
          },
          {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "enum": ["automatic", "manual", "approval", "conditional"]
              },
              "phase": {
                "type": "string",
                "enum": ["preflight", "flight", "postflight"],
                "description": "Execution phase of the step"
              },
              "description": {
                "type": "string"
              },
              "command": {
                "type": "string"
              },
              "script": {
                "type": "string",
                "description": "Path to an external shell script (relative to operation file). Content is read and embedded in generated manuals."
              },
              "instruction": {
                "type": "string"
              },
              "if": {
                "type": "string",
                "description": "Condition for conditional steps"
              },
              "timeout": {
                "type": "number",
                "minimum": 0
              },
              "estimated_duration": {
                "type": "number",
                "minimum": 0
              },
              "env": {
                "type": "object"
              },
              "uses": {
                "type": "string",
                "description": "Path to a file whose steps are expanded inline here (relative to operation file)"
              },
              "with": {
                "type": "object",
                "description": "Variables to pass to the included file (all ${VAR} placeholders must be provided)"
              },
              "variables": {
                "type": "object",
                "description": "Step-scoped variables that override environment and common variables"
              },
              "evidence": {
                "type": "object",
                "properties": {
                  "required": {
                    "type": "boolean"
                  },
                  "types": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "screenshot",
                        "log",
                        "command_output",
                        "file",
                        "photo",
                        "video"
                      ]
                    }
                  },
                  "results": {
                    "type": "object",
                    "description": "Environment-keyed evidence results (e.g., { staging: [...], production: [...] })",
                    "additionalProperties": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["type"],
                        "properties": {
                          "type": {
                            "type": "string",
                            "enum": [
                              "screenshot",
                              "log",
                              "command_output",
                              "file",
                              "photo",
                              "video"
                            ]
                          },
                          "file": {
                            "type": "string",
                            "description": "File path reference (relative to operation file)"
                          },
                          "content": {
                            "type": "string",
                            "description": "Inline content (for text-based evidence)"
                          },
                          "description": {
                            "type": "string",
                            "description": "Optional description or context"
                          }
                        },
                        "oneOf": [
                          { "required": ["file"] },
                          { "required": ["content"] }
                        ]
                      }
                    }
                  }
                }
              },
              "continue_on_error": {
                "type": "boolean"
              },
              "needs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "sub_steps": {
                "type": "array",
                "items": {
                  "$ref": "#/properties/steps/items"
                }
              },
              "manual_override": {
                "type": "boolean"
              },
              "manual_instructions": {
                "type": "string"
              },
              "ticket": {
                "oneOf": [
                  {
                    "type": "string",
                    "description": "Single ticket reference (e.g., JIRA-123)"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Multiple ticket references"
                  }
                ],
                "description": "Bug/issue ticket references"
              },
              "foreach": {
                "oneOf": [
                  {
                    "type": "object",
                    "required": ["var", "values"],
                    "properties": {
                      "var": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Variable name to use in iteration"
                      },
                      "values": {
                        "type": "array",
                        "minItems": 1,
                        "description": "Array of values to iterate over"
                      }
                    },
                    "additionalProperties": false,
                    "description": "Single variable foreach loop"
                  },
                  {
                    "type": "object",
                    "required": ["matrix"],
                    "properties": {
                      "matrix": {
                        "type": "object",
                        "minProperties": 1,
                        "additionalProperties": {
                          "type": "array",
                          "minItems": 1
                        },
                        "description": "Matrix of variables for cartesian product expansion"
                      },
                      "include": {
                        "type": "array",
                        "items": {
                          "type": "object"
                        },
                        "description": "Additional specific variable combinations to include"
                      },
                      "exclude": {
                        "type": "array",
                        "items": {
                          "type": "object"
                        },
                        "description": "Specific variable combinations to exclude"
                      }
                    },
                    "additionalProperties": false,
                    "description": "Matrix expansion with multiple variables (cartesian product)"
                  }
                ],
                "description": "Loop/matrix support for repeatable steps"
              },
              "section_heading": {
                "type": "boolean",
                "description": "If true, render as a new markdown heading instead of table row"
              },
              "pic": {
                "type": "string",
                "description": "Person In Charge for this step"
              },
              "reviewer": {
                "type": "string",
                "description": "Reviewer/buddy who monitors and verifies the PIC's work"
              },
              "session": {
                "type": "string",
                "description": "Named tmux session to use for this step (execution engine)"
              },
              "capture": {
                "type": "object",
                "description": "Extract named values from command output for use in later steps",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "pattern": {
                      "type": "string",
                      "description": "Regex pattern with capture group"
                    },
                    "group": {
                      "type": "number",
                      "minimum": 0,
                      "description": "Capture group index (default 1)"
                    },
                    "line": {
                      "type": "string",
                      "enum": ["last", "first"],
                      "description": "Extract specific line"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "expect": {
                "description": "Assert this step's output. String shorthand = expect contains.",
                "oneOf": [
                  { "type": "string" },
                  { "$ref": "#/definitions/expectConfig" },
                  {
                    "type": "array",
                    "items": { "$ref": "#/definitions/expectConfig" },
                    "minItems": 1
                  }
                ]
              },
              "timeline": {
                "oneOf": [
                  {
                    "type": "string",
                    "description": "Legacy format: raw Mermaid timeline syntax (e.g., '2024-01-15 09:00, 30m')"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "start": {
                        "type": "string",
                        "description": "Absolute start time (e.g., '2024-01-15 09:00')"
                      },
                      "duration": {
                        "type": "string",
                        "description": "Duration (e.g., '30m', '2h', '1d')"
                      },
                      "after": {
                        "type": "string",
                        "description": "Dependency on another step name"
                      },
                      "status": {
                        "type": "string",
                        "enum": ["active", "done", "crit"],
                        "description": "Mermaid status"
                      }
                    },
                    "additionalProperties": false,
                    "description": "Structured timeline configuration (auto-converts to Mermaid syntax)"
                  }
                ],
                "description": "Expected date/time or duration for this step (string or structured format)"
              },
              "options": {
                "type": "object",
                "properties": {
                  "substitute_vars": {
                    "type": "boolean",
                    "default": true,
                    "description": "Substitute ${VAR} in instruction and command (default: true)"
                  },
                  "show_command_separately": {
                    "type": "boolean",
                    "default": false,
                    "description": "Show command in separate section from instruction (default: false)"
                  }
                },
                "additionalProperties": false,
                "description": "Step-level rendering and substitution options"
              },
              "when": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "minItems": 1,
                "description": "Conditional rendering: only show this step for specified environments"
              },
              "variants": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "type": {
                      "type": "string",
                      "enum": ["automatic", "manual", "approval", "conditional"]
                    },
                    "description": { "type": "string" },
                    "command": { "type": "string" },
                    "instruction": { "type": "string" },
                    "timeout": { "type": "number", "minimum": 0 },
                    "estimated_duration": { "type": "number", "minimum": 0 },
                    "env": { "type": "object" },
                    "variables": { "type": "object" },
                    "evidence": {
                      "$ref": "#/properties/steps/items/oneOf/1/properties/evidence"
                    },
                    "continue_on_error": { "type": "boolean" },
                    "pic": { "type": "string" },
                    "reviewer": { "type": "string" },
                    "ticket": {
                      "$ref": "#/properties/steps/items/oneOf/1/properties/ticket"
                    },
                    "rollback": {
                      "$ref": "#/properties/steps/items/oneOf/1/properties/rollback"
                    },
                    "retry": {
                      "$ref": "#/properties/steps/items/oneOf/1/properties/retry"
                    },
                    "approval": {
                      "$ref": "#/properties/steps/items/oneOf/1/properties/approval"
                    },
                    "options": {
                      "$ref": "#/properties/steps/items/oneOf/1/properties/options"
                    }
                  },
                  "additionalProperties": false
                },
                "description": "Environment-specific step overrides (can override any step field except 'when' and 'variants')"
              },
              "rollback": {
                "description": "Rollback steps for this step. Array format preferred; object format accepted for backward compatibility (parser normalizes to array).",
                "oneOf": [
                  {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string" },
                        "command": { "type": "string" },
                        "script": {
                          "type": "string",
                          "description": "Path to an external shell script (relative to operation file). Content is read and embedded in generated manuals."
                        },
                        "instruction": { "type": "string" },
                        "timeout": { "type": "number", "minimum": 0 },
                        "session": {
                          "type": "string",
                          "description": "Session to run rollback in (defaults to step session)"
                        },
                        "description": { "type": "string" },
                        "pic": { "type": "string" },
                        "reviewer": { "type": "string" },
                        "type": { "type": "string" },
                        "expect": {
                          "description": "Assert this rollback step's output. String shorthand = expect contains.",
                          "oneOf": [
                            { "type": "string" },
                            { "$ref": "#/definitions/expectConfig" },
                            {
                              "type": "array",
                              "items": { "$ref": "#/definitions/expectConfig" },
                              "minItems": 1
                            }
                          ]
                        },
                        "sub_steps": {
                          "type": "array",
                          "description": "Nested rollback sub-steps, rendered recursively under this rollback step",
                          "items": { "$ref": "#/definitions/rollbackStep" }
                        },
                        "options": {
                          "type": "object",
                          "properties": {
                            "substitute_vars": {
                              "type": "boolean",
                              "default": true
                            },
                            "show_command_separately": {
                              "type": "boolean",
                              "default": false
                            }
                          },
                          "additionalProperties": false
                        }
                      },
                      "not": {
                        "required": ["command", "script"]
                      }
                    },
                    "description": "Rollback steps (preferred format)"
                  },
                  {
                    "type": "object",
                    "description": "Single rollback step (backward-compatible object format)",
                    "properties": {
                      "name": { "type": "string" },
                      "command": { "type": "string" },
                      "script": {
                        "type": "string",
                        "description": "Path to an external shell script (relative to operation file). Content is read and embedded in generated manuals."
                      },
                      "instruction": { "type": "string" },
                      "timeout": { "type": "number", "minimum": 0 },
                      "description": { "type": "string" },
                      "pic": { "type": "string" },
                      "reviewer": { "type": "string" },
                      "type": { "type": "string" },
                      "expect": {
                        "description": "Assert this rollback step's output. String shorthand = expect contains.",
                        "oneOf": [
                          { "type": "string" },
                          { "$ref": "#/definitions/expectConfig" },
                          {
                            "type": "array",
                            "items": { "$ref": "#/definitions/expectConfig" },
                            "minItems": 1
                          }
                        ]
                      },
                      "sub_steps": {
                        "type": "array",
                        "description": "Nested rollback sub-steps, rendered recursively under this rollback step",
                        "items": { "$ref": "#/definitions/rollbackStep" }
                      },
                      "options": {
                        "type": "object",
                        "properties": {
                          "substitute_vars": {
                            "type": "boolean",
                            "default": true
                          },
                          "show_command_separately": {
                            "type": "boolean",
                            "default": false
                          }
                        },
                        "additionalProperties": false
                      }
                    },
                    "not": {
                      "required": ["command", "script"]
                    }
                  }
                ]
              },
              "retry": {
                "type": "object",
                "properties": {
                  "attempts": {
                    "type": "number",
                    "minimum": 1
                  },
                  "delay": {
                    "type": "number",
                    "minimum": 0
                  },
                  "backoff": {
                    "type": "string",
                    "enum": ["linear", "exponential"]
                  }
                }
              },
              "approval": {
                "type": "object",
                "properties": {
                  "required": {
                    "type": "boolean"
                  },
                  "approvers": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "timeout": {
                    "type": "string"
                  }
                }
              }
            },
            "not": {
              "required": ["command", "script"]
            }
          }
        ]
      }
    },
    "rollback": {
      "type": "object",
      "properties": {
        "automatic": {
          "type": "boolean"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/definitions/rollbackStep" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "type": "string"
        },
        "git_hash": {
          "type": "string"
        }
      }
    }
  },
  "definitions": {
    "rollbackStep": {
      "type": "object",
      "description": "A rollback step. Structurally like a normal step: it may carry an optional name and nest sub_steps (rendered recursively in the rollback plan).",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "script": {
          "type": "string",
          "description": "Path to an external shell script whose content is embedded in the manual"
        },
        "instruction": {
          "type": "string"
        },
        "timeout": {
          "type": "number",
          "minimum": 0
        },
        "session": {
          "type": "string",
          "description": "Session to run rollback in (defaults to step session)"
        },
        "type": {
          "type": "string"
        },
        "pic": {
          "type": "string",
          "description": "Person In Charge of executing this rollback step"
        },
        "reviewer": {
          "type": "string",
          "description": "Reviewer/buddy who verifies this rollback step"
        },
        "evidence": {
          "$ref": "#/properties/steps/items/oneOf/1/properties/evidence"
        },
        "expect": {
          "description": "Assert this rollback step's output. String shorthand = expect contains.",
          "oneOf": [
            { "type": "string" },
            { "$ref": "#/definitions/expectConfig" },
            {
              "type": "array",
              "items": { "$ref": "#/definitions/expectConfig" },
              "minItems": 1
            }
          ]
        },
        "sub_steps": {
          "type": "array",
          "description": "Nested rollback sub-steps, rendered recursively under this step",
          "items": { "$ref": "#/definitions/rollbackStep" }
        },
        "options": {
          "type": "object",
          "properties": {
            "substitute_vars": {
              "type": "boolean",
              "default": true,
              "description": "Substitute ${VAR} in instruction and command (default: true)"
            },
            "show_command_separately": {
              "type": "boolean",
              "default": false,
              "description": "Show command in separate section from instruction (default: false)"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "expectConfig": {
      "type": "object",
      "description": "Rule-based assertion config for verify output",
      "properties": {
        "contains": { "type": "string" },
        "not_contains": { "type": "string" },
        "equals": { "type": "string" },
        "matches": { "type": "string" },
        "not_empty": { "type": "boolean" },
        "any_line_contains": { "type": "string" },
        "no_line_contains": { "type": "string" },
        "all_lines_match": { "type": "string" },
        "line_count": { "type": "number", "minimum": 0 },
        "line_count_gte": { "type": "number", "minimum": 0 },
        "numeric_gte": { "type": "number" },
        "numeric_lte": { "type": "number" },
        "jsonpath": { "type": "string" },
        "equals_captured": { "type": "string" },
        "retry": {
          "type": "object",
          "required": ["interval", "max"],
          "properties": {
            "interval": {
              "type": "string",
              "description": "Polling interval e.g. '5s', '500ms', '1m'"
            },
            "max": {
              "type": "number",
              "minimum": 1,
              "description": "Max retry count"
            },
            "while": {
              "type": "string",
              "description": "Only retry while the captured output matches this pattern (substring or regex) — a retryable/transient marker; otherwise fail fast"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
