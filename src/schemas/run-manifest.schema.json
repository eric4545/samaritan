{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://samaritan.dev/schemas/run-manifest",
  "title": "RunManifest",
  "description": "Evidence and metadata for a single execution of an operation",
  "type": "object",
  "required": ["id", "operation", "environment", "status"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this run (e.g. prod-2025-10-20-v1)"
    },
    "operation": {
      "type": "string",
      "description": "Relative path to the operation YAML file (from this manifest's location)"
    },
    "operation_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 content hash of the operation file at run time (sha256:<hex>)"
    },
    "operation_commit": {
      "type": "string",
      "description": "Git commit hash of the operation file at run time"
    },
    "environment": {
      "type": "string",
      "description": "Environment this run was executed against"
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the run started"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the run completed"
    },
    "operator": {
      "type": "string",
      "description": "Primary operator who executed this run"
    },
    "status": {
      "type": "string",
      "enum": ["in_progress", "completed", "failed", "aborted"],
      "description": "Final status of this run"
    },
    "steps": {
      "type": "object",
      "description": "Evidence collected per step, keyed by step.id or slugified step.name",
      "additionalProperties": {
        "$ref": "#/definitions/RunStepEvidence"
      }
    }
  },
  "definitions": {
    "RunStepEvidence": {
      "type": "object",
      "required": ["evidence"],
      "additionalProperties": false,
      "properties": {
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/definitions/RunEvidenceItem" }
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "operator": {
          "type": "string"
        }
      }
    },
    "RunEvidenceItem": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "oneOf": [
        {
          "required": ["file"],
          "properties": {
            "type": { "$ref": "#/definitions/EvidenceType" },
            "file": { "type": "string" },
            "description": { "type": "string" },
            "captured_at": { "type": "string", "format": "date-time" }
          }
        },
        {
          "required": ["content"],
          "properties": {
            "type": { "$ref": "#/definitions/EvidenceType" },
            "content": { "type": "string" },
            "description": { "type": "string" },
            "captured_at": { "type": "string", "format": "date-time" }
          }
        }
      ]
    },
    "EvidenceType": {
      "type": "string",
      "enum": ["screenshot", "file", "photo", "video", "log", "command_output"]
    }
  }
}
