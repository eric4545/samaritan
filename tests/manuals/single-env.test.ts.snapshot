exports[`Single-env heading-based Markdown manual (issue #15) > snapshot: withCaptureExpect — verify with command+expect, expect-only, and verify-only shapes 1`] = `
"# Capture and Expect Test — Staging\\n\\n## Step 1: Build image\\n\\n**Command**\\n\\n\`\`\`bash\\ndocker build -t myapp .\\n\`\`\`\\n\\n---\\n\\n## Step 2: Check pod count\\n\\n**Verify**\\n\`\`\`bash\\nkubectl get pods -n prod | grep -c Running\\n\`\`\`\\n> Expected: at least 1 line(s)\\n\\n---\\n\\n## Step 3: Deploy\\n\\n**Command**\\n\\n\`\`\`bash\\nkubectl set image deployment/myapp myapp=myapp:latest\\n\`\`\`\\n\\n**Verify**\\n\`\`\`bash\\nkubectl get pod -l app=myapp -o jsonpath='{.items[0].spec.containers[0].imageID}'\\n\`\`\`\\n> Expected: contains: \${IMAGE_ID}\\n\\n---\\n\\n## Step 4: Health check\\n\\n**Verify**\\n\`\`\`bash\\ncurl -s https://staging.example.com/health | jq .status\\n\`\`\`\\n> Expected: equals \\"healthy\\"\\n"
`;

exports[`Single-env heading-based Markdown manual (issue #15) > snapshot: withSessions — verify string shorthand rendered as expect block 1`] = `
"# Deploy with Sessions — Production\\n\\n## Step 1: Deploy App\\n\\n**Command**\\n\\n\`\`\`bash\\nkubectl apply -f deployment.yaml\\n\`\`\`\\n\\n**Verify**\\n\`\`\`bash\\nkubectl get pods -n prod\\n\`\`\`\\n> Expected: contains: Running\\n\\n### 🔄 Rollback\\n\\n**Command**\\n\`\`\`bash\\nkubectl rollout undo deployment/web\\n\`\`\`\\n\\n---\\n\\n## Step 2: Build Image\\n\\n**Command**\\n\\n\`\`\`bash\\ndocker build -t myapp .\\n\`\`\`\\n\\n> Expected: Successfully built\\n"
`;
