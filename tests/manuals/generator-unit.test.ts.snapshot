exports[`Verify / expect rendering snapshots > multi-env table: verify string shorthand normalised to expect-only 1`] = `
"# Manual for: Deploy with Sessions (v1.0.0)\\n\\n_Tests sessions, rollback array, capture, and expect_\\n\\n## Environments Overview\\n\\n| Environment | Description | Variables | Targets | Approval Required |\\n| ----------- | ----------- | --------- | ------- | ----------------- |\\n| production | Production environment | REPLICAS: 3 |  | Yes |\\n\\n## ✈️ Flight Phase (Main Operations)\\n\\n| Step | production |\\n|------|---------|\\n| [ ] Step 1: Deploy App ✈️👤 | \`kubectl apply -f deployment.yaml\` |\\n\\n### 🔄 Rollback for Step 1: Deploy App\\n\\n| Environment | Rollback Action |\\n|-------------|----------------|\\n| production | \`kubectl rollout undo deployment/web\` |\\n\\n| Step | production |\\n|------|---------|\\n| [ ] Step 2: Check Deployment ✈️👤 | \`kubectl get pods -n prod\`<br>_Expected:_<br>- [ ] _contains: Running_ |\\n| [ ] Step 3: Build Image ✈️👤 | \`docker build -t myapp .\`<br>_Expected:_<br>- [ ] _Successfully built_ |\\n\\n## 🔄 Rollback Procedures\\n\\nIf deployment fails, execute the following rollback steps:\\n\\n### Rollback for: Deploy App\\n\\n| Environment | Rollback Action |\\n|-------------|----------------|\\n| production | \`kubectl rollout undo deployment/web\` |\\n\\n"
`;

exports[`Verify / expect rendering snapshots > multi-env table: verify with command+expect, expect-only, and verify-only-command 1`] = `
"# Manual for: Capture and Expect Test (v1.0.0)\\n\\n_Tests capture and all assertion types_\\n\\n## Environments Overview\\n\\n| Environment | Description | Variables | Targets | Approval Required |\\n| ----------- | ----------- | --------- | ------- | ----------------- |\\n| staging | Staging environment | ENDPOINT: \\"https://staging.example.com\\" |  | No |\\n\\n## ✈️ Flight Phase (Main Operations)\\n\\n| Step | staging |\\n|------|---------|\\n| [ ] Step 1: Build image ✈️👤 | \`docker build -t myapp .\` |\\n| [ ] Step 2: Check pod count ✈️👤 | \`kubectl get pods -n prod \\\\| grep -c Running\`<br>_Expected:_<br>- [ ] _at least 1 line(s)_<br>- [ ] _value ≥ 3_ |\\n| [ ] Step 3: Deploy ✈️👤 | \`kubectl set image deployment/myapp myapp=myapp:latest\` |\\n| [ ] Step 4: Verify image ✈️👤 | \`kubectl get pod -l app=myapp -o jsonpath='{.items[0].spec.containers[0].imageID}'\`<br>_Expected:_<br>- [ ] _contains: \${IMAGE_ID}_ |\\n| [ ] Step 5: Health check ✈️👤 | \`curl -s https://staging.example.com/health \\\\| jq .status\`<br>_Expected:_<br>- [ ] _equals \\"healthy\\"_ |\\n\\n"
`;
